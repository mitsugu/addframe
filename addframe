#! /bin/bash
files=`ls "${1}"`

if [ $# -lt 2 ]; then
	echo "Usage :"
	echo "    addframe <filename> <output_directory>"
	echo "        filename : you can use wildcards."
	echo "        output_directory_path : output directory path name"
	exit 0
fi

if [ ! -d ${2} ]; then
	echo "Not found directory!! Specify an existing directory."
	exit 1
fi

rotateImage() { # {{{
	length="1280"	# 画像長辺サイズ
	top="32"		# 上辺幅
	left="32"		# 左辺幅
	right="32"		# 右辺幅
	bottom="128"	# 下辺幅

	ext=${2##*.}
	if [ "${ext}" != "HEIC" ]; then
		convert "${2}" -resize ${length}x -quality 100 webp:- | convert - -auto-orient -quality 100 tmp2.webp
	else
		convert "${2}" -resize x${length} -quality 100 webp:- | convert - -auto-orient -quality 100 tmp2.webp
	fi
} # }}}

createFrame() { #{{{
	#data=$(exiftool -s -T -Orientation -ImageWidth -ImageHeight -Model -Make  -LensModel -LensID -FNumber -ShutterSpeed -ISO "${tfile}" | column -d -s "\t")
	length="1280"	# 画像長辺サイズ
	top="32"		# 上辺幅
	left="32"		# 左辺幅
	right="32"		# 右辺幅
	bottom="128"	# 下辺幅
	font=Noto-Sans-CJK-JP

	orient=$(echo "${1}" | cut -f 1)
	width=$(echo "${1}" | cut -f 2)
	height=$(echo "${1}" | cut -f 3)
	camera=$(echo "${1}" | cut -f 4)
	make=$(echo "${1}" | cut -f 5)
	lens=$(echo "${1}" | cut -f 6)
	if [ "${lens}" == "" -o "${lens}" == "-" ]; then
		lens=$(echo "${1}" | cut -f 7)
	fi
	fnumber=$(echo "${1}" | cut -f 8)
	ss=$(echo "${1}" | cut -f 9)
	iso=$(echo "${1}" | cut -f 10)
	tmpH=$(expr ${height} "*" 1280 "/" ${width})
	flg=`expr "${orient}" : "^Rotate"`
	if [ ${flg} -eq 0 ]; then
		w=$(expr 1280 + ${left} + ${right})
		h=$(expr ${tmpH} + ${top} + ${bottom})
	else
		w=$(expr ${tmpH} + ${left} + ${right})
		h=$(expr 1280 + ${top} + ${bottom})
	fi
	convert -size ${w}x${h} xc:#ffffff webp:- |
	convert - \
			-pointsize "24" \
			-font ${font} \
			-fill black \
			-gravity south \
			-annotate +0+64 "Shot on ${camera}" \
			-quality 100 \
			- | \
	convert - \
			-font ${font} \
			-pointsize "16" \
			-fill black \
			-gravity south \
			-annotate +0+40 "${make}" \
			-quality 100 \
			- | \
	convert - \
			-font ${font} \
			-pointsize "16" \
			-fill "#838383" \
			-gravity south \
			-annotate +0+16 "$lens f${fnumber} ${ss}s ISO${iso}" \
			-quality 100 \
			tmp1.webp
} # }}}

mergeImage() { # {{{
	convert tmp1.webp tmp2.webp -gravity north -geometry +0+32 -compose over -composite ${1}"/"${2}
	rm tmp1.webp tmp2.webp
} # }}}

for tfile in ${files}
do
	echo "Just a second..."

	data=$(exiftool -s -T -Orientation -ImageWidth -ImageHeight -Model -Make  -LensModel -LensID -FNumber -ShutterSpeed -ISO "${tfile}" | column -d -s "\t")
	createFrame "${data}"
	rotateImage "${data}" "${tfile}"
	mergeImage ${2} ${tfile}
	echo "Done!!"
done

